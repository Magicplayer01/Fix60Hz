<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.fix60hz"
    android:versionCode="99"
    android:versionName="1.3" >

    <uses-sdk
        android:minSdkVersion="31"
        android:targetSdkVersion="34" />

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="false"
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:label="Fix60Hz"
        android:supportsRtl="true" >

        <!-- Xposed module metadata -->
        <meta-data
            android:name="xposedmodule"
            android:value="true" />
        <meta-data
            android:name="xposeddescription"
            android:value="Forces 60Hz refresh rate. Fix for replaced screens on Realme GT 5G (RMX2202) ColorOS 14." />
        <meta-data
            android:name="xposedminversion"
            android:value="93" />

        <!-- UI Activity -->
        <activity
            android:name="com.example.fix60hz.MainActivity"
            android:exported="true"
            android:label="Fix60Hz" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>